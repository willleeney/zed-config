{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "OneDark Deeper",
  "author": "will",
  "themes": [
    {
      "name": "OneDark Deeper",
      "appearance": "dark",
      "style": {
        "background": "#1e1f22",
        "editor.background": "#232528",
        "editor.gutter.background": "#232528",
        "editor.active_line.background": "#292b2f",
        "editor.line_number": "#55575e",
        "editor.active_line_number": "#a8a9ad",
        "editor.wrap_guide": "#2f3135",
        "editor.highlighted_line.background": "#292b2f",
        "editor.invisible": "#55575e",

        "surface.background": "#202123",
        "elevated_surface.background": "#2c2e32",
        "element.background": "#202123",
        "element.hover": "#2c2e32",
        "element.active": "#363840",
        "element.selected": "#363840",
        "element.disabled": "#202123",

        "drop_target.background": "#36384080",
        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#2c2e32",
        "ghost_element.active": "#363840",
        "ghost_element.selected": "#363840",
        "ghost_element.disabled": "#202123",

        "text": "#a8a9ad",
        "text.muted": "#6e7078",
        "text.placeholder": "#55575e",
        "text.disabled": "#55575e",
        "text.accent": "#91B4F9",

        "icon": "#a8a9ad",
        "icon.muted": "#6e7078",
        "icon.disabled": "#55575e",
        "icon.placeholder": "#55575e",
        "icon.accent": "#91B4F9",

        "selection": "#363840",
        "editor.document_highlight.read_background": "#36384066",
        "editor.document_highlight.write_background": "#36384099",

        "border": "#2f3135",
        "border.variant": "#2f3135",
        "border.focused": "#43454a",
        "border.selected": "#91B4F9",
        "border.transparent": "#00000000",
        "border.disabled": "#2f3135",

        "tab_bar.background": "#1e1f22",
        "tab.inactive_background": "#1e1f22",
        "tab.active_background": "#232528",

        "toolbar.background": "#232528",
        "title_bar.background": "#1e1f22",
        "title_bar.inactive_background": "#1e1f22",
        "status_bar.background": "#1e1f22",
        "panel.background": "#202123",
        "panel.focused_border": "#43454a",

        "pane.focused_border": "#43454a",

        "scrollbar.thumb.background": "#36384066",
        "scrollbar.thumb.hover_background": "#43454a88",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "#00000000",

        "terminal.background": "#232528",
        "terminal.foreground": "#a8a9ad",
        "terminal.bright_foreground": "#c5c6c9",
        "terminal.dim_foreground": "#6e7078",
        "terminal.ansi.black": "#202123",
        "terminal.ansi.bright_black": "#55575e",
        "terminal.ansi.red": "#F4787B",
        "terminal.ansi.bright_red": "#F4787B",
        "terminal.ansi.green": "#92CEB0",
        "terminal.ansi.bright_green": "#92CEB0",
        "terminal.ansi.yellow": "#dcc592",
        "terminal.ansi.bright_yellow": "#dcc592",
        "terminal.ansi.blue": "#91B4F9",
        "terminal.ansi.bright_blue": "#91B4F9",
        "terminal.ansi.magenta": "#c48fdf",
        "terminal.ansi.bright_magenta": "#c48fdf",
        "terminal.ansi.cyan": "#7bc3cc",
        "terminal.ansi.bright_cyan": "#7bc3cc",
        "terminal.ansi.white": "#a8a9ad",
        "terminal.ansi.bright_white": "#c5c6c9",

        "link_text.hover": "#91B4F9",

        "conflict": "#dcc592",
        "conflict.border": "#dcc592",
        "conflict.background": "#dcc59222",
        "created": "#92CEB0",
        "created.border": "#92CEB0",
        "created.background": "#92CEB022",
        "deleted": "#F4787B",
        "deleted.border": "#F4787B",
        "deleted.background": "#F4787B22",
        "error": "#F4787B",
        "error.border": "#F4787B",
        "error.background": "#F4787B22",
        "hidden": "#55575e",
        "hidden.border": "#55575e",
        "hidden.background": "#55575e22",
        "hint": "#6e7078",
        "hint.border": "#6e7078",
        "hint.background": "#6e707822",
        "ignored": "#55575e",
        "ignored.border": "#55575e",
        "ignored.background": "#55575e22",
        "info": "#7bc3cc",
        "info.border": "#7bc3cc",
        "info.background": "#7bc3cc22",
        "modified": "#dcc592",
        "modified.border": "#dcc592",
        "modified.background": "#dcc59222",
        "predictive": "#55575e",
        "predictive.border": "#55575e",
        "predictive.background": "#55575e22",
        "renamed": "#91B4F9",
        "renamed.border": "#91B4F9",
        "renamed.background": "#91B4F922",
        "success": "#92CEB0",
        "success.border": "#92CEB0",
        "success.background": "#92CEB022",
        "unreachable": "#55575e",
        "unreachable.border": "#55575e",
        "unreachable.background": "#55575e22",
        "warning": "#dcc592",
        "warning.border": "#dcc592",
        "warning.background": "#dcc59222",

        "players": [
          { "cursor": "#91B4F9", "background": "#91B4F9", "selection": "#91B4F933" },
          { "cursor": "#92CEB0", "background": "#92CEB0", "selection": "#92CEB033" },
          { "cursor": "#c48fdf", "background": "#c48fdf", "selection": "#c48fdf33" },
          { "cursor": "#dcc592", "background": "#dcc592", "selection": "#dcc59233" },
          { "cursor": "#7bc3cc", "background": "#7bc3cc", "selection": "#7bc3cc33" },
          { "cursor": "#F4787B", "background": "#F4787B", "selection": "#F4787B33" },
          { "cursor": "#CEA36C", "background": "#CEA36C", "selection": "#CEA36C33" }
        ],

        "syntax": {
          "attribute": { "color": "#CEA36C" },
          "boolean": { "color": "#CEA36C" },
          "comment": { "color": "#9a8ddb", "font_style": "italic" },
          "comment.doc": { "color": "#a99de8", "font_style": "italic" },
          "constant": { "color": "#CEA36C" },
          "constructor": { "color": "#91B4F9" },
          "embedded": { "color": "#a8a9ad" },
          "emphasis": { "color": "#F4787B", "font_style": "italic" },
          "emphasis.strong": { "color": "#F4787B", "font_weight": 700 },
          "enum": { "color": "#dcc592" },
          "function": { "color": "#91B4F9" },
          "function.builtin": { "color": "#7bc3cc" },
          "hint": { "color": "#6e7078" },
          "keyword": { "color": "#c48fdf" },
          "label": { "color": "#F4787B" },
          "link_text": { "color": "#92CEB0" },
          "link_uri": { "color": "#7bc3cc" },
          "number": { "color": "#CEA36C" },
          "operator": { "color": "#7bc3cc" },
          "predictive": { "color": "#55575e" },
          "preproc": { "color": "#c48fdf" },
          "primary": { "color": "#a8a9ad" },
          "property": { "color": "#F4787B" },
          "punctuation": { "color": "#a8a9ad" },
          "punctuation.bracket": { "color": "#a8a9ad" },
          "punctuation.delimiter": { "color": "#a8a9ad" },
          "punctuation.list_marker": { "color": "#F4787B" },
          "punctuation.special": { "color": "#7bc3cc" },
          "string": { "color": "#92CEB0" },
          "string.escape": { "color": "#7bc3cc" },
          "string.regex": { "color": "#7bc3cc" },
          "string.special": { "color": "#CEA36C" },
          "string.special.symbol": { "color": "#F4787B" },
          "tag": { "color": "#F4787B" },
          "text.literal": { "color": "#92CEB0" },
          "title": { "color": "#F4787B", "font_weight": 700 },
          "type": { "color": "#dcc592" },
          "type.builtin": { "color": "#dcc592" },
          "variable": { "color": "#F4787B" },
          "variable.special": { "color": "#F4787B" },
          "variant": { "color": "#91B4F9" }
        }
      }
    }
  ]
}
